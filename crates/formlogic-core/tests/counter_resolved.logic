// ============================================================================
// Counter example — pure formlogic
// Demonstrates: createNode, setBuilderFn, event handling, state, invalidate
// ============================================================================

// ============================================================================
// softn-formlogic stdlib: runtime.logic
// Core rendering framework — component registry, tree building, layout, render
// ============================================================================

// NOTE: color.logic and components/index.logic are imported AFTER core
// definitions below, because component files call registerComponent() etc.
// at top level during import resolution.

// ============================================================================
// Theme / default styles
// ============================================================================

let _theme = {
    fontFamily: "system-ui",
    fontSize: 14,
    fontWeight: 400,
    color: "#1a1a2e",
    background: "#ffffff",
    primary: "#6366f1",
    primaryHover: "#4f46e5",
    secondary: "#64748b",
    success: "#22c55e",
    warning: "#f59e0b",
    error: "#ef4444",
    info: "#3b82f6",
    borderColor: "#e2e8f0",
    borderRadius: 8,
    spacing: 8,
    inputBg: "#ffffff",
    inputBorder: "#cbd5e1",
    disabledBg: "#f1f5f9",
    disabledColor: "#94a3b8",
    cardBg: "#ffffff",
    cardShadow: "rgba(0,0,0,0.08)",
    modalOverlay: "rgba(0,0,0,0.5)",
    tooltipBg: "#1e293b",
    tooltipColor: "#f8fafc"
};

function getTheme() { return _theme; }
function setTheme(overrides) {
    let keys = Object.keys(overrides);
    for (let i = 0; i < keys.length; i++) {
        _theme[keys[i]] = overrides[keys[i]];
    }
}

// ============================================================================
// Component Registry
// ============================================================================

let _componentRenderers = {};

function registerComponent(name, renderFn) {
    _componentRenderers[name] = renderFn;
}

// ============================================================================
// Style defaults by component type
// ============================================================================

let _defaultStyles = {};

function registerDefaultStyle(componentType, style) {
    _defaultStyles[componentType] = style;
}

// ============================================================================
// Component tree node structure
// ============================================================================
// A component node:
// {
//   type: string,          // e.g. "Box", "Text", "Button"
//   props: {},             // component-specific properties
//   style: {},             // CSS-like style properties
//   children: [],          // child component nodes
//   layoutNode: number,    // taffy node handle (set during layout phase)
//   _computedLayout: null  // {x, y, width, height} after layout
// }

// Create a component node
function createNode(type, props, style, children) {
    return {
        type: type || "Box",
        props: props || {},
        style: style || {},
        children: children || [],
        layoutNode: 0,
        _computedLayout: null,
        _parentX: 0,
        _parentY: 0
    };
}

// ============================================================================
// Style resolution
// ============================================================================

// Merge style from: defaults -> component defaults -> inline style -> props
function resolveStyle(node) {
    let base = {
        display: "flex",
        flexDirection: "column",
        position: "relative",
        overflow: "visible",
        flexWrap: "nowrap",
        justifyContent: "flex-start",
        alignItems: "stretch",
        alignContent: "flex-start",
        alignSelf: "auto",
        flexGrow: 0,
        flexShrink: 1,
        flexBasis: "auto",
        width: "auto",
        height: "auto",
        minWidth: "auto",
        minHeight: "auto",
        maxWidth: "auto",
        maxHeight: "auto",
        paddingTop: 0,
        paddingRight: 0,
        paddingBottom: 0,
        paddingLeft: 0,
        marginTop: 0,
        marginRight: 0,
        marginBottom: 0,
        marginLeft: 0,
        borderTopWidth: 0,
        borderRightWidth: 0,
        borderBottomWidth: 0,
        borderLeftWidth: 0,
        gapRow: 0,
        gapColumn: 0,
        top: "auto",
        right: "auto",
        bottom: "auto",
        left: "auto",
        aspectRatio: null,
        order: 0,
        zIndex: 0
    };

    // Apply component type defaults
    let typeDef = _defaultStyles[node.type];
    if (typeDef) {
        let keys = Object.keys(typeDef);
        for (let i = 0; i < keys.length; i++) {
            base[keys[i]] = typeDef[keys[i]];
        }
    }

    // Apply inline style
    let nodeStyle = node.style;
    if (nodeStyle) {
        let skeys = Object.keys(nodeStyle);
        for (let i = 0; i < skeys.length; i++) {
            let key = skeys[i];
            let val = nodeStyle[key];

            // Handle shorthand properties
            if (key === "padding") {
                let p = _parseSpacing(val);
                base.paddingTop = p[0];
                base.paddingRight = p[1];
                base.paddingBottom = p[2];
                base.paddingLeft = p[3];
            } else if (key === "margin") {
                let m = _parseSpacing(val);
                base.marginTop = m[0];
                base.marginRight = m[1];
                base.marginBottom = m[2];
                base.marginLeft = m[3];
            } else if (key === "borderWidth") {
                base.borderTopWidth = val;
                base.borderRightWidth = val;
                base.borderBottomWidth = val;
                base.borderLeftWidth = val;
            } else if (key === "gap") {
                base.gapRow = val;
                base.gapColumn = val;
            } else if (key === "inset") {
                let ins = _parseSpacing(val);
                base.top = ins[0];
                base.right = ins[1];
                base.bottom = ins[2];
                base.left = ins[3];
            } else {
                base[key] = val;
            }
        }
    }

    return base;
}

// Parse a spacing shorthand (like CSS margin/padding)
// Can be: number, [top, right, bottom, left], [vertical, horizontal], [all]
function _parseSpacing(val) {
    if (typeof val === "number") {
        return [val, val, val, val];
    }
    if (Array.isArray(val)) {
        if (val.length === 1) return [val[0], val[0], val[0], val[0]];
        if (val.length === 2) return [val[0], val[1], val[0], val[1]];
        if (val.length === 3) return [val[0], val[1], val[2], val[1]];
        if (val.length >= 4) return [val[0], val[1], val[2], val[3]];
    }
    return [0, 0, 0, 0];
}

// Convert resolved style to a layout bridge style object
function _styleToLayoutStyle(s) {
    return {
        display: s.display || "flex",
        position: s.position || "relative",
        overflow: s.overflow || "visible",
        flexDirection: s.flexDirection || "column",
        flexWrap: s.flexWrap || "nowrap",
        justifyContent: s.justifyContent || "flex-start",
        alignItems: s.alignItems || "stretch",
        alignContent: s.alignContent || "flex-start",
        alignSelf: s.alignSelf || "auto",
        flexGrow: s.flexGrow || 0,
        flexShrink: s.flexShrink !== undefined ? s.flexShrink : 1,
        flexBasis: _dimValue(s.flexBasis),
        width: _dimValue(s.width),
        height: _dimValue(s.height),
        minWidth: _dimValue(s.minWidth),
        minHeight: _dimValue(s.minHeight),
        maxWidth: _dimValue(s.maxWidth),
        maxHeight: _dimValue(s.maxHeight),
        padding: [
            s.paddingTop || 0,
            s.paddingRight || 0,
            s.paddingBottom || 0,
            s.paddingLeft || 0
        ],
        margin: [
            _dimValue(s.marginTop),
            _dimValue(s.marginRight),
            _dimValue(s.marginBottom),
            _dimValue(s.marginLeft)
        ],
        border: [
            s.borderTopWidth || 0,
            s.borderRightWidth || 0,
            s.borderBottomWidth || 0,
            s.borderLeftWidth || 0
        ],
        inset: [
            _dimValue(s.top),
            _dimValue(s.right),
            _dimValue(s.bottom),
            _dimValue(s.left)
        ],
        gap: [s.gapRow || 0, s.gapColumn || 0],
        aspectRatio: s.aspectRatio,
        order: s.order || 0,
        zIndex: s.zIndex || 0,
        gridTemplateColumns: s.gridTemplateColumns || [],
        gridTemplateRows: s.gridTemplateRows || [],
        gridColumnStart: s.gridColumnStart || "auto",
        gridColumnEnd: s.gridColumnEnd || "auto",
        gridRowStart: s.gridRowStart || "auto",
        gridRowEnd: s.gridRowEnd || "auto"
    };
}

// Convert a dimension value to a layout bridge dimension spec
// "auto" -> {type: "auto"}
// number -> {type: "points", value: n}
// "50%" -> {type: "percent", value: 50}
function _dimValue(val) {
    if (val === undefined || val === null || val === "auto") {
        return { type: "auto" };
    }
    if (typeof val === "number") {
        return { type: "points", value: val };
    }
    if (typeof val === "string") {
        if (val.indexOf("%") >= 0) {
            let pct = parseFloat(val);
            if (!isNaN(pct)) {
                return { type: "percent", value: pct };
            }
        }
        let num = parseFloat(val);
        if (!isNaN(num)) {
            return { type: "points", value: num };
        }
    }
    return { type: "auto" };
}

// ============================================================================
// Layout phase — create taffy nodes for the tree
// ============================================================================

function buildLayout(node) {
    let resolved = resolveStyle(node);
    node._resolvedStyle = resolved;

    // Special handling for text nodes: measure text to set intrinsic size
    if (node.type === "Text" || node.type === "Heading") {
        _measureTextNode(node, resolved);
    }

    let layoutStyle = _styleToLayoutStyle(resolved);
    node.layoutNode = layout.createNode(layoutStyle);

    // Recursively build children
    let childNodes = [];
    let childCount = node.children.length;
    for (let i = 0; i < childCount; i++) {
        let child = node.children[i];
        buildLayout(child);
        childNodes.push(child.layoutNode);
    }

    if (childNodes.length > 0) {
        layout.setChildren(node.layoutNode, childNodes);
    }

    return node;
}

function _measureTextNode(node, resolved) {
    let text = node.props.text || node.props.value || "";
    if (text === "") return;

    let fontSize = node.props.fontSize || resolved.fontSize || _theme.fontSize;
    let fontWeight = node.props.fontWeight || resolved.fontWeight || _theme.fontWeight;
    let fontFamily = node.props.fontFamily || _theme.fontFamily;
    let maxWidth = 0;

    // If width is set, use it as max width for text measurement
    if (resolved.width && resolved.width !== "auto" && typeof resolved.width === "number") {
        maxWidth = resolved.width - (resolved.paddingLeft || 0) - (resolved.paddingRight || 0);
    }

    let measured = draw.measureText(text, fontSize, fontWeight, fontFamily, maxWidth);
    if (measured) {
        // Only set size if not explicitly specified
        if (resolved.width === "auto" || resolved.width === undefined) {
            node.style._measuredWidth = measured.width + (resolved.paddingLeft || 0) + (resolved.paddingRight || 0);
        }
        if (resolved.height === "auto" || resolved.height === undefined) {
            node.style._measuredHeight = measured.height + (resolved.paddingTop || 0) + (resolved.paddingBottom || 0);
        }
    }
}

// ============================================================================
// Compute layout
// ============================================================================

function computeLayout(rootNode, availWidth, availHeight) {
    layout.computeLayout(rootNode.layoutNode, availWidth, availHeight);
    _collectLayouts(rootNode, 0, 0);
}

function _collectLayouts(node, parentX, parentY) {
    let l = layout.getLayout(node.layoutNode);
    node._computedLayout = {
        x: l.x + parentX,
        y: l.y + parentY,
        width: l.width,
        height: l.height,
        localX: l.x,
        localY: l.y
    };
    node._parentX = parentX;
    node._parentY = parentY;

    let absX = node._computedLayout.x;
    let absY = node._computedLayout.y;

    // For absolute/fixed positioned children, they position relative to this node
    for (let i = 0; i < node.children.length; i++) {
        let child = node.children[i];
        let pos = child._resolvedStyle ? child._resolvedStyle.position : "relative";
        if (pos === "absolute" || pos === "fixed") {
            _collectLayouts(child, absX, absY);
        } else {
            _collectLayouts(child, absX, absY);
        }
    }
}

// ============================================================================
// Render phase — draw components
// ============================================================================

function renderTree(node) {
    if (!node || !node._computedLayout) return;

    let cl = node._computedLayout;

    // Skip if zero-size or display:none
    if (node._resolvedStyle && node._resolvedStyle.display === "none") return;
    if (cl.width <= 0 && cl.height <= 0) return;

    // Clear per-frame flags
    node._childrenRendered = false;
    node._animTransformPushed = false;
    node._animOpacityPushed = false;
    node._dragTransformPushed = false;

    // Look up and call the component renderer
    let renderer = _componentRenderers[node.type];
    if (renderer) {
        renderer(node, cl);
    }

    // If the component already rendered its children (Marquee, Collapse, etc.), skip
    if (!node._childrenRendered) {
        // Sort children by z-index and render
        let children = node.children;
        if (children.length > 0) {
            // Clip if overflow hidden/scroll
            let needsClip = false;
            if (node._resolvedStyle) {
                let ov = node._resolvedStyle.overflow;
                if (ov === "hidden" || ov === "scroll") {
                    needsClip = true;
                    let br = node.props.borderRadius || node._resolvedStyle.borderRadius || 0;
                    draw.pushClip(cl.x, cl.y, cl.width, cl.height, br);
                }
            }

            // Sort by z-index (stable)
            let sorted = _sortByZIndex(children);
            for (let i = 0; i < sorted.length; i++) {
                renderTree(sorted[i]);
            }

            if (needsClip) {
                draw.popClip();
            }
        }
    }

    // Pop any transforms/opacity pushed by the component renderer
    if (node._animOpacityPushed) {
        draw.popOpacity();
    }
    if (node._animTransformPushed) {
        draw.popTransform();
    }
    if (node._dragTransformPushed) {
        draw.popTransform();
    }
}

function _sortByZIndex(children) {
    if (children.length <= 1) return children;
    // Check if any child has non-zero z-index
    let needsSort = false;
    for (let i = 0; i < children.length; i++) {
        let z = children[i]._resolvedStyle ? (children[i]._resolvedStyle.zIndex || 0) : 0;
        if (z !== 0) { needsSort = true; break; }
    }
    if (!needsSort) return children;

    // Simple insertion sort (stable) on z-index
    let arr = [];
    for (let i = 0; i < children.length; i++) arr.push(children[i]);
    for (let i = 1; i < arr.length; i++) {
        let key = arr[i];
        let keyZ = key._resolvedStyle ? (key._resolvedStyle.zIndex || 0) : 0;
        let j = i - 1;
        while (j >= 0) {
            let jZ = arr[j]._resolvedStyle ? (arr[j]._resolvedStyle.zIndex || 0) : 0;
            if (jZ > keyZ) {
                arr[j + 1] = arr[j];
                j = j - 1;
            } else {
                break;
            }
        }
        arr[j + 1] = key;
    }
    return arr;
}

// ============================================================================
// Full render pipeline
// ============================================================================

// _rootNode: the component tree root (built by the app or UI parser)
let _rootNode = null;
let _needsRebuild = true;
let _builderFn = null;

function setRootNode(node) {
    _rootNode = node;
    _needsRebuild = true;
}

function getRootNode() {
    return _rootNode;
}

// Register a builder function that will be called every frame to rebuild the UI.
// This enables reactivity: when state changes, the UI tree is automatically rebuilt.
function setBuilderFn(fn) {
    _builderFn = fn;
}

// Main render function — called by the host each frame
function _render() {
    let vw = draw.getViewportWidth();
    let vh = draw.getViewportHeight();
    if (vw <= 0 || vh <= 0) return;

    // If a builder function is registered, rebuild the tree every frame
    if (_builderFn) {
        _rootNode = _builderFn();
        _needsRebuild = true;
    }

    if (!_rootNode) return;

    // Dispatch input events
    _dispatchEvents();

    // Clear with background color
    draw.rect(0, 0, vw, vh, _theme.background, 0, 0, "", 1);

    // Rebuild layout if needed
    if (_needsRebuild) {
        layout.clear();
        buildLayout(_rootNode);
        _needsRebuild = false;
    }

    // Compute layout
    computeLayout(_rootNode, vw, vh);

    // Render
    renderTree(_rootNode);
}

// Request a re-render (marks tree as needing layout rebuild)
function invalidate() {
    _needsRebuild = true;
    input.requestRedraw();
}

// Request redraw without full layout rebuild (e.g. for animations)
function requestRedraw() {
    input.requestRedraw();
}

// ============================================================================
// Hit testing
// ============================================================================

function hitTest(node, x, y) {
    if (!node || !node._computedLayout) return null;
    let cl = node._computedLayout;

    // Check children in reverse z-order (top-most first)
    let children = _sortByZIndex(node.children);
    for (let i = children.length - 1; i >= 0; i--) {
        let hit = hitTest(children[i], x, y);
        if (hit) return hit;
    }

    // Check this node
    if (x >= cl.x && x < cl.x + cl.width && y >= cl.y && y < cl.y + cl.height) {
        return node;
    }
    return null;
}

// ============================================================================
// State management helpers
// ============================================================================

let _state = {};

function setState(key, value) {
    _state[key] = value;
    invalidate();
}

function getState(key, defaultValue) {
    if (_state[key] !== undefined) return _state[key];
    return defaultValue;
}

// ============================================================================
// Import color utilities and component renderers
// These must come AFTER all core definitions (registerComponent, _theme,
// renderTree, getState, setState, etc.) since component files call them
// at top level during import.
// ============================================================================

// ============================================================================
// softn-formlogic stdlib: color.logic
// Color parsing and manipulation utilities
// ============================================================================

// Named CSS colors (subset)
let _namedColors = {
    "white": [255, 255, 255, 1],
    "black": [0, 0, 0, 1],
    "red": [255, 0, 0, 1],
    "green": [0, 128, 0, 1],
    "blue": [0, 0, 255, 1],
    "yellow": [255, 255, 0, 1],
    "orange": [255, 165, 0, 1],
    "purple": [128, 0, 128, 1],
    "pink": [255, 192, 203, 1],
    "cyan": [0, 255, 255, 1],
    "gray": [128, 128, 128, 1],
    "grey": [128, 128, 128, 1],
    "transparent": [0, 0, 0, 0],
    "coral": [255, 127, 80, 1],
    "crimson": [220, 20, 60, 1],
    "navy": [0, 0, 128, 1],
    "teal": [0, 128, 128, 1],
    "olive": [128, 128, 0, 1],
    "maroon": [128, 0, 0, 1],
    "indigo": [75, 0, 130, 1],
    "violet": [238, 130, 238, 1],
    "gold": [255, 215, 0, 1],
    "silver": [192, 192, 192, 1],
    "brown": [165, 42, 42, 1],
    "tan": [210, 180, 140, 1],
    "salmon": [250, 128, 114, 1],
    "tomato": [255, 99, 71, 1],
    "lime": [0, 255, 0, 1],
    "aqua": [0, 255, 255, 1],
    "skyblue": [135, 206, 235, 1],
    "steelblue": [70, 130, 180, 1],
    "slategray": [112, 128, 144, 1],
    "darkgray": [169, 169, 169, 1],
    "lightgray": [211, 211, 211, 1],
    "whitesmoke": [245, 245, 245, 1],
    "beige": [245, 245, 220, 1],
    "ivory": [255, 255, 240, 1],
    "linen": [250, 240, 230, 1],
    "snow": [255, 250, 250, 1],
    "honeydew": [240, 255, 240, 1],
    "mintcream": [245, 255, 250, 1],
    "aliceblue": [240, 248, 255, 1],
    "ghostwhite": [248, 248, 255, 1],
    "seashell": [255, 245, 238, 1],
    "lavender": [230, 230, 250, 1],
    "cornflowerblue": [100, 149, 237, 1],
    "dodgerblue": [30, 144, 255, 1],
    "royalblue": [65, 105, 225, 1],
    "mediumblue": [0, 0, 205, 1],
    "darkblue": [0, 0, 139, 1],
    "midnightblue": [25, 25, 112, 1],
    "darkgreen": [0, 100, 0, 1],
    "forestgreen": [34, 139, 34, 1],
    "limegreen": [50, 205, 50, 1],
    "springgreen": [0, 255, 127, 1],
    "darkred": [139, 0, 0, 1],
    "firebrick": [178, 34, 34, 1],
    "orangered": [255, 69, 0, 1],
    "darkorange": [255, 140, 0, 1],
    "deeppink": [255, 20, 147, 1],
    "hotpink": [255, 105, 180, 1],
    "mediumorchid": [186, 85, 211, 1],
    "darkorchid": [153, 50, 204, 1],
    "darkviolet": [148, 0, 211, 1],
    "blueviolet": [138, 43, 226, 1]
};

// Parse a single hex digit
function _hexVal(c) {
    if (c >= 48 && c <= 57) return c - 48;        // '0'-'9'
    if (c >= 97 && c <= 102) return c - 97 + 10;   // 'a'-'f'
    if (c >= 65 && c <= 70) return c - 65 + 10;     // 'A'-'F'
    return 0;
}

// Parse a color string to [r, g, b, a] where r,g,b are 0-255 and a is 0-1
function parseColor(s) {
    if (s === undefined || s === null || s === "" || s === "none") {
        return [0, 0, 0, 0];
    }
    s = s.trim();

    // Named color lookup
    let lower = s.toLowerCase();
    if (_namedColors[lower] !== undefined) {
        return _namedColors[lower];
    }

    // Hex color
    if (s[0] === "#") {
        let hex = s.slice(1);
        if (hex.length === 3) {
            let r = _hexVal(hex.charCodeAt(0)) * 17;
            let g = _hexVal(hex.charCodeAt(1)) * 17;
            let b = _hexVal(hex.charCodeAt(2)) * 17;
            return [r, g, b, 1];
        }
        if (hex.length === 6) {
            let r = _hexVal(hex.charCodeAt(0)) * 16 + _hexVal(hex.charCodeAt(1));
            let g = _hexVal(hex.charCodeAt(2)) * 16 + _hexVal(hex.charCodeAt(3));
            let b = _hexVal(hex.charCodeAt(4)) * 16 + _hexVal(hex.charCodeAt(5));
            return [r, g, b, 1];
        }
        if (hex.length === 8) {
            let r = _hexVal(hex.charCodeAt(0)) * 16 + _hexVal(hex.charCodeAt(1));
            let g = _hexVal(hex.charCodeAt(2)) * 16 + _hexVal(hex.charCodeAt(3));
            let b = _hexVal(hex.charCodeAt(4)) * 16 + _hexVal(hex.charCodeAt(5));
            let a = _hexVal(hex.charCodeAt(6)) * 16 + _hexVal(hex.charCodeAt(7));
            return [r, g, b, a / 255];
        }
    }

    // rgb() / rgba()
    if (s.indexOf("rgb") === 0) {
        let start = s.indexOf("(");
        let end = s.lastIndexOf(")");
        if (start >= 0 && end > start) {
            let inner = s.slice(start + 1, end);
            let parts = inner.split(",");
            let r = Math.round(parseFloat(parts[0] || "0"));
            let g = Math.round(parseFloat(parts[1] || "0"));
            let b = Math.round(parseFloat(parts[2] || "0"));
            let a = parts.length > 3 ? parseFloat(parts[3] || "1") : 1;
            return [
                Math.max(0, Math.min(255, r)),
                Math.max(0, Math.min(255, g)),
                Math.max(0, Math.min(255, b)),
                Math.max(0, Math.min(1, a))
            ];
        }
    }

    // Fallback: black
    return [0, 0, 0, 1];
}

// Convert [r,g,b,a] to a CSS-style color string for the draw bridge
function colorToString(rgba) {
    if (rgba[3] < 1) {
        return `rgba(${rgba[0]},${rgba[1]},${rgba[2]},${rgba[3]})`;
    }
    let r = rgba[0].toString(16);
    let g = rgba[1].toString(16);
    let b = rgba[2].toString(16);
    if (r.length < 2) r = "0" + r;
    if (g.length < 2) g = "0" + g;
    if (b.length < 2) b = "0" + b;
    return "#" + r + g + b;
}

// Lighten a color by a factor (0-1)
function lightenColor(colorStr, factor) {
    let c = parseColor(colorStr);
    let r = Math.min(255, Math.round(c[0] + (255 - c[0]) * factor));
    let g = Math.min(255, Math.round(c[1] + (255 - c[1]) * factor));
    let b = Math.min(255, Math.round(c[2] + (255 - c[2]) * factor));
    return colorToString([r, g, b, c[3]]);
}

// Darken a color by a factor (0-1)
function darkenColor(colorStr, factor) {
    let c = parseColor(colorStr);
    let r = Math.max(0, Math.round(c[0] * (1 - factor)));
    let g = Math.max(0, Math.round(c[1] * (1 - factor)));
    let b = Math.max(0, Math.round(c[2] * (1 - factor)));
    return colorToString([r, g, b, c[3]]);
}

// Set alpha on a color
function withAlpha(colorStr, alpha) {
    let c = parseColor(colorStr);
    return `rgba(${c[0]},${c[1]},${c[2]},${alpha})`;
}

// ============================================================================
// Component Index — imports all component registration files
// ============================================================================
// Import order: foundational types first, then more complex ones.

// ============================================================================
// Layout Components: Box, Stack, Card, Grid, Divider, Spacer, Center,
//                    Container, Header, Sidebar, Section, Split, Layout, Content
// ============================================================================

// ─── Box ────────────────────────────────────────────────────────────────────
// The most versatile component: a div with full flexbox control, background
// (solid/gradient), border, border-radius, box-shadow, opacity, transforms.
registerComponent("Box", (node, cl) => {
    let p = node.props;
    let s = node._resolvedStyle;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;

    let opacity = p.opacity !== undefined ? p.opacity : 1;
    if (p.visible === false) return;

    // Box shadow (rendered before the box)
    if (p.boxShadow) {
        let sh = p.boxShadow;
        let ox = sh.offsetX || 0;
        let oy = sh.offsetY || 0;
        let blur = sh.blur || 0;
        let spread = sh.spread || 0;
        let sc = sh.color || "rgba(0,0,0,0.3)";
        let br = p.borderRadius || s.borderRadius || 0;

        if (blur > 0) {
            let layers = Math.max(1, Math.ceil(blur / 2));
            for (let i = layers - 1; i >= 0; i--) {
                let expand = (i + 1) * (blur / layers) + spread;
                let a = (1 - i / layers) * 0.15;
                let shadowColor = withAlpha(sc, a);
                draw.roundedRect(
                    x + ox - expand, y + oy - expand,
                    w + expand * 2, h + expand * 2,
                    shadowColor, br + expand, 0, "", opacity
                );
            }
        } else if (spread > 0) {
            draw.roundedRect(
                x + ox - spread, y + oy - spread,
                w + spread * 2, h + spread * 2,
                sc, (p.borderRadius || 0) + spread, 0, "", opacity
            );
        }
    }

    // Background
    let bg = p.background || s.background;
    let br = p.borderRadius || s.borderRadius || 0;
    if (p.borderRadiusPct) {
        br = Math.min(w, h) * br / 100;
    }

    if (bg && bg !== "transparent") {
        if (typeof bg === "object" && bg.type === "linearGradient") {
            let angle = bg.angle || 0;
            draw.linearGradient(x, y, w, h, angle, bg.stops || [], br, opacity);
        } else if (typeof bg === "object" && bg.type === "radialGradient") {
            draw.radialGradient(x, y, w, h, bg.stops || [], br, opacity);
        } else {
            draw.roundedRect(x, y, w, h, bg, br, 0, "", opacity);
        }
    }

    // Border
    let bw = p.borderWidth || s.borderTopWidth || 0;
    let bc = p.borderColor || s.borderColor;
    if (bw > 0 && bc) {
        draw.roundedRect(x, y, w, h, "", br, bw, bc, opacity);
    }
});

// ─── Stack ──────────────────────────────────────────────────────────────────
// Simplified Box with mandatory direction semantics. Vertical or Horizontal.
registerComponent("Stack", (node, cl) => {
    let p = node.props;
    let bg = p.background;
    if (bg && bg !== "transparent") {
        draw.roundedRect(cl.x, cl.y, cl.width, cl.height, bg, 0, 0, "", 1);
    }
});

// ─── Card ───────────────────────────────────────────────────────────────────
// Rounded-rect container with variant-based styling, optional title/subtitle.
registerComponent("Card", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;
    let variant = p.variant || "default";

    // Variant defaults
    let bg = p.background;
    let bc = p.borderColor;
    let bw = p.borderWidth;
    let br = p.borderRadius !== undefined ? p.borderRadius : 12;

    if (bg === undefined) {
        if (variant === "outlined") { bg = "transparent"; }
        else if (variant === "elevated") { bg = "#16161a"; }
        else if (variant === "filled") { bg = "#1e1e23"; }
        else if (variant === "ghost") { bg = "transparent"; }
        else if (variant === "glass") { bg = "rgba(255,255,255,0.05)"; }
        else if (variant === "gradient") { bg = "#6366f1"; }
        else { bg = "#16161a"; }
    }
    if (bc === undefined) {
        if (variant === "outlined") { bc = "#52525b"; }
        else if (variant === "elevated" || variant === "gradient" || variant === "ghost") { bc = "transparent"; }
        else if (variant === "glass") { bc = "rgba(255,255,255,0.1)"; }
        else { bc = "rgba(255,255,255,0.08)"; }
    }
    if (bw === undefined) {
        if (variant === "elevated" || variant === "gradient" || variant === "ghost") { bw = 0; }
        else { bw = 1; }
    }

    // Selected override
    if (p.selected) {
        bc = "#6366f1";
        if (bw < 2) bw = 2;
    }

    // Draw card background
    if (bg && bg !== "transparent") {
        draw.roundedRect(x, y, w, h, bg, br, 0, "", 1);
    }

    // Border
    if (bw > 0 && bc && bc !== "transparent") {
        draw.roundedRect(x, y, w, h, "", br, bw, bc, 1);
    }

    // Title
    let padding = p.padding || 16;
    if (p.title) {
        draw.text(p.title, x + padding, y + padding, 18, 600, "#fafafa",
            _theme.fontFamily, w - padding * 2, 1);
    }
    // Subtitle
    if (p.subtitle) {
        let titleOffset = p.title ? 24 : 0;
        draw.text(p.subtitle, x + padding, y + padding + titleOffset, 14, 400, "#a1a1aa",
            _theme.fontFamily, w - padding * 2, 1);
    }
});

// ─── Grid ───────────────────────────────────────────────────────────────────
// CSS Grid container (columns of equal width).
registerComponent("Grid", (node, cl) => {
    let p = node.props;
    let bg = p.background;
    if (bg && bg !== "transparent") {
        draw.rect(cl.x, cl.y, cl.width, cl.height, bg, 0, 0, "", 1);
    }
});

// ─── Divider ────────────────────────────────────────────────────────────────
// Horizontal line separator.
registerComponent("Divider", (node, cl) => {
    let p = node.props;
    let color = p.color || "rgba(255,255,255,0.2)";
    let thickness = p.thickness || 1;
    draw.rect(cl.x, cl.y, cl.width, thickness, color, 0, 0, "", 1);
});

// ─── Spacer ─────────────────────────────────────────────────────────────────
// Invisible spacing element. Renders nothing.
registerComponent("Spacer", (node, cl) => {
    // No visual rendering — purely a layout tool.
});

// ─── Center ─────────────────────────────────────────────────────────────────
// Centers children both horizontally and vertically.
registerComponent("Center", (node, cl) => {
    let p = node.props;
    let bg = p.background;
    if (bg && bg !== "transparent") {
        draw.rect(cl.x, cl.y, cl.width, cl.height, bg, 0, 0, "", 1);
    }
});

// ─── Container ──────────────────────────────────────────────────────────────
// Centered column with maxWidth, like Bootstrap's .container.
registerComponent("Container", (node, cl) => {
    let p = node.props;
    let bg = p.background;
    if (bg && bg !== "transparent") {
        draw.rect(cl.x, cl.y, cl.width, cl.height, bg, 0, 0, "", 1);
    }
});

// ─── Header ─────────────────────────────────────────────────────────────────
// Fixed-height horizontal bar with optional bottom border.
registerComponent("Header", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;

    let bg = p.background;
    if (bg && bg !== "transparent") {
        draw.rect(x, y, w, h, bg, 0, 0, "", 1);
    }

    // Bottom border
    let borderBottom = p.borderBottom !== undefined ? p.borderBottom : true;
    if (borderBottom) {
        let bc = p.borderColor || "rgba(255,255,255,0.1)";
        draw.line(x, y + h, x + w, y + h, bc, 1);
    }
});

// ─── Sidebar ────────────────────────────────────────────────────────────────
// Fixed-width vertical column with optional right border.
registerComponent("Sidebar", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;

    let bg = p.background;
    if (bg && bg !== "transparent") {
        draw.rect(x, y, w, h, bg, 0, 0, "", 1);
    }

    // Right border
    let borderRight = p.borderRight !== undefined ? p.borderRight : true;
    if (borderRight) {
        let bc = p.borderColor || "rgba(255,255,255,0.1)";
        draw.line(x + w, y, x + w, y + h, bc, 1);
    }
});

// ─── Section ────────────────────────────────────────────────────────────────
// Vertical stack with optional title and 12px gap.
registerComponent("Section", (node, cl) => {
    let p = node.props;
    let bg = p.background;
    if (bg && bg !== "transparent") {
        draw.rect(cl.x, cl.y, cl.width, cl.height, bg, 0, 0, "", 1);
    }
});

// ─── Split ──────────────────────────────────────────────────────────────────
// Splits space between children by a ratio.
registerComponent("Split", (node, cl) => {
    let p = node.props;
    let bg = p.background;
    if (bg && bg !== "transparent") {
        draw.rect(cl.x, cl.y, cl.width, cl.height, bg, 0, 0, "", 1);
    }
});

// ─── Layout ─────────────────────────────────────────────────────────────────
// Full-page layout shell (100% x 100%). Contains Header, Sidebar, Content.
registerComponent("Layout", (node, cl) => {
    let p = node.props;
    let bg = p.background;
    if (bg && bg !== "transparent") {
        draw.rect(cl.x, cl.y, cl.width, cl.height, bg, 0, 0, "", 1);
    }
});

// ─── Content ────────────────────────────────────────────────────────────────
// Main scrollable content area within a Layout. flex:1, overflow-y:scroll.
registerComponent("Content", (node, cl) => {
    let p = node.props;
    let bg = p.background;
    if (bg && bg !== "transparent") {
        draw.rect(cl.x, cl.y, cl.width, cl.height, bg, 0, 0, "", 1);
    }
});

// ─── Default styles for layout components ──────────────────────────────────

registerDefaultStyle("Box", {
    display: "flex",
    flexDirection: "column"
});

registerDefaultStyle("Stack", {
    display: "flex",
    flexDirection: "column",
    width: "100%"
});

registerDefaultStyle("Card", {
    display: "flex",
    flexDirection: "column",
    width: "100%",
    overflow: "hidden",
    padding: 16
});

registerDefaultStyle("Grid", {
    display: "grid",
    width: "100%"
});

registerDefaultStyle("Divider", {
    width: "100%",
    height: 1,
    marginTop: 4,
    marginBottom: 4,
    flexShrink: 0
});

registerDefaultStyle("Spacer", {
    flexGrow: 1
});

registerDefaultStyle("Center", {
    display: "flex",
    justifyContent: "center",
    alignItems: "center",
    width: "100%",
    height: "100%"
});

registerDefaultStyle("Container", {
    display: "flex",
    flexDirection: "column",
    width: "100%",
    maxWidth: 1200,
    marginLeft: "auto",
    marginRight: "auto",
    padding: 16
});

registerDefaultStyle("Header", {
    display: "flex",
    flexDirection: "row",
    alignItems: "center",
    width: "100%",
    height: 56,
    padding: 16,
    flexShrink: 0
});

registerDefaultStyle("Sidebar", {
    display: "flex",
    flexDirection: "column",
    width: 240,
    height: "100%",
    flexShrink: 0
});

registerDefaultStyle("Section", {
    display: "flex",
    flexDirection: "column",
    width: "100%",
    padding: 16,
    gapRow: 12
});

registerDefaultStyle("Split", {
    display: "flex",
    flexDirection: "row",
    width: "100%",
    height: "100%"
});

registerDefaultStyle("Layout", {
    display: "flex",
    flexDirection: "column",
    width: "100%",
    height: "100%"
});

registerDefaultStyle("Content", {
    display: "flex",
    flexDirection: "column",
    flexGrow: 1,
    padding: 16,
    overflow: "hidden"
});

// ============================================================================
// Text Components: Text, Heading
// ============================================================================

// ─── Text ───────────────────────────────────────────────────────────────────
// Pure text rendering with variant-based colors, transforms, decorations.
registerComponent("Text", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;

    let text = p.text || p.value || "";
    if (text === "") return;

    // Text transform
    let transform = p.transform || "none";
    if (transform === "uppercase") text = text.toUpperCase();
    else if (transform === "lowercase") text = text.toLowerCase();
    else if (transform === "capitalize") {
        text = text.split(" ").map(word => {
            if (word.length === 0) return word;
            return word[0].toUpperCase() + word.slice(1);
        }).join(" ");
    }

    // Variant-based color defaults
    let color = p.color;
    if (!color) {
        let variant = p.variant || "default";
        if (variant === "muted") color = "#a1a1aa";
        else if (variant === "primary") color = "#6366f1";
        else if (variant === "secondary") color = "#a1a1aa";
        else if (variant === "success") color = "#22c55e";
        else if (variant === "warning") color = "#f59e0b";
        else if (variant === "error") color = "#ef4444";
        else if (variant === "info") color = "#3b82f6";
        else color = _theme.color;
    }

    let fontSize = p.fontSize || _theme.fontSize;
    let fontWeight = p.fontWeight || _theme.fontWeight;
    let fontFamily = p.fontFamily || _theme.fontFamily;
    let opacity = p.opacity !== undefined ? p.opacity : 1;

    // Padding offsets
    let s = node._resolvedStyle;
    let px = (s.paddingLeft || 0);
    let py = (s.paddingTop || 0);

    draw.text(text, x + px, y + py, fontSize, fontWeight, color,
        fontFamily, w - px - (s.paddingRight || 0), opacity);
});

// ─── Heading ────────────────────────────────────────────────────────────────
// Header text with level-based sizing (h1-h6).
registerComponent("Heading", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;

    let text = p.text || p.value || "";
    if (text === "") return;

    let level = p.level || 1;

    // Level-based defaults
    let fontSize = p.fontSize;
    let fontWeight = p.fontWeight;
    if (!fontSize) {
        if (level === 1) fontSize = 36;
        else if (level === 2) fontSize = 30;
        else if (level === 3) fontSize = 24;
        else if (level === 4) fontSize = 20;
        else if (level === 5) fontSize = 18;
        else fontSize = 16;
    }
    if (!fontWeight) {
        if (level <= 2) fontWeight = 700;
        else fontWeight = 600;
    }

    // Variant-based color
    let color = p.color;
    if (!color) {
        let variant = p.variant || "default";
        if (variant === "muted") color = "#a1a1aa";
        else if (variant === "primary" || variant === "gradient") color = "#6366f1";
        else color = _theme.color;
    }

    let fontFamily = p.fontFamily || _theme.fontFamily;
    let opacity = p.opacity !== undefined ? p.opacity : 1;

    let s = node._resolvedStyle;
    let px = (s.paddingLeft || 0);
    let py = (s.paddingTop || 0);

    draw.text(text, x + px, y + py, fontSize, fontWeight, color,
        fontFamily, w - px - (s.paddingRight || 0), opacity);
});

// ─── Default styles ─────────────────────────────────────────────────────────

registerDefaultStyle("Text", {
    flexShrink: 1
});

registerDefaultStyle("Heading", {
    flexShrink: 0
});

// ============================================================================
// Input/Form Components: Button, Input, TextArea, Select, Switch, Checkbox,
//                        Radio, Slider
// ============================================================================

// ─── Button ─────────────────────────────────────────────────────────────────
registerComponent("Button", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;

    let variant = p.variant || "primary";
    let disabled = p.disabled || p.loading;
    let opacity = disabled ? 0.5 : 1;

    let bg = p.background || _theme.primary;
    let fg = p.color || "#ffffff";
    let br = p.borderRadius !== undefined ? p.borderRadius : _theme.borderRadius;
    let bw = p.borderWidth || 0;
    let bc = p.borderColor || bg;

    // Variant-specific rendering
    if (variant === "outline") {
        // No fill, border only
        draw.roundedRect(x, y, w, h, "", br, Math.max(bw, 1), bc, opacity);
    } else if (variant === "ghost" || variant === "link") {
        // No fill, no border
    } else if (variant === "secondary") {
        draw.roundedRect(x, y, w, h, bg, br, 0, "", opacity);
        if (bw > 0) {
            draw.roundedRect(x, y, w, h, "", br, bw, bc, opacity);
        }
    } else {
        // Primary, Danger, Success, Warning — solid fill
        if (variant === "danger") bg = p.background || _theme.error;
        else if (variant === "success") bg = p.background || _theme.success;
        else if (variant === "warning") bg = p.background || _theme.warning;
        draw.roundedRect(x, y, w, h, bg, br, 0, "", opacity);
    }

    // Label
    let label = p.loading ? "..." : (p.label || "");
    if (label) {
        let fontSize = p.fontSize || 14;
        let fontWeight = variant === "link" ? 400 : 500;
        let textX = x + 12;
        let textY = y + (h - fontSize * 1.2) / 2;
        let maxW = w - 24;
        draw.text(label, textX, textY, fontSize, fontWeight, fg,
            _theme.fontFamily, maxW, opacity);
    }
});

// ─── Input ──────────────────────────────────────────────────────────────────
registerComponent("Input", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;

    let currentY = y;

    // Label
    if (p.label) {
        draw.text(p.label, x, currentY, 14, 500, "rgba(217,217,222,1)",
            _theme.fontFamily, w, 1);
        currentY = currentY + 20;
    }

    // Input field dimensions
    let size = p.size || "md";
    let inputHeight = 40;
    if (size === "sm") inputHeight = 32;
    else if (size === "lg") inputHeight = 44;

    let variant = p.variant || "outline";
    let bg = p.background || _theme.inputBg;
    let br = p.borderRadius !== undefined ? p.borderRadius : 6;
    let bc = p.borderColor || _theme.inputBorder;
    let fontSize = p.fontSize || 14;
    let disabled = p.disabled;
    let opacity = disabled ? 0.6 : 1;

    // Focus/error/success state
    let focused = false;
    if (p.bindVar) {
        focused = input.getFocusedInput() === p.bindVar;
    }
    let strokeWidth = 1;
    if (focused) { bc = "#6366f1"; strokeWidth = 2; }
    if (p.error) { bc = "#ef4444"; strokeWidth = 2; }
    if (p.success) { bc = "#22c55e"; strokeWidth = 2; }

    // Draw field
    if (variant === "flushed") {
        // Background
        draw.rect(x, currentY, w, inputHeight, bg, 0, 0, "", opacity);
        // Bottom border only
        draw.line(x, currentY + inputHeight, x + w, currentY + inputHeight, bc, strokeWidth);
    } else {
        draw.roundedRect(x, currentY, w, inputHeight, bg, br, strokeWidth, bc, opacity);
    }

    // Value or placeholder text
    let value = p.value || "";
    let textColor = p.color || _theme.color;
    let textY = currentY + (inputHeight - fontSize * 1.2) / 2;

    if (p.inputType === "password" && value) {
        value = "•".repeat(value.length);
    }

    if (value) {
        draw.text(value, x + 14, textY, fontSize, 400, textColor,
            _theme.fontFamily, w - 28, opacity);
    } else if (p.placeholder) {
        draw.text(p.placeholder, x + 14, textY, fontSize, 400, "rgba(161,161,168,1)",
            _theme.fontFamily, w - 28, opacity);
    }

    // Cursor when focused
    if (focused) {
        let cursorX = x + 14;
        if (value) {
            let measured = draw.measureText(value, fontSize, 400, _theme.fontFamily, 0);
            if (measured) cursorX = cursorX + measured.width;
        }
        let elapsed = input.getElapsedSecs();
        if ((elapsed * 2) % 2 < 1) {
            draw.rect(cursorX, textY + fontSize * 0.15, 1.5, fontSize, textColor, 0, 0, "", opacity);
        }
    }

    currentY = currentY + inputHeight;

    // Error message
    if (p.error && p.errorMessage) {
        draw.text(p.errorMessage, x, currentY + 4, 12, 400, "#ef4444",
            _theme.fontFamily, w, 1);
    }
    // Helper text
    else if (p.helperText) {
        let helperColor = p.success ? "#22c55e" : "rgba(161,161,168,1)";
        draw.text(p.helperText, x, currentY + 4, 12, 400, helperColor,
            _theme.fontFamily, w, 1);
    }
});

// ─── TextArea ───────────────────────────────────────────────────────────────
registerComponent("TextArea", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;

    let bg = p.background || _theme.inputBg;
    let br = p.borderRadius !== undefined ? p.borderRadius : 6;
    let bc = p.borderColor || _theme.inputBorder;
    let fontSize = p.fontSize || 14;
    let disabled = p.disabled;
    let opacity = disabled ? 0.6 : 1;

    // Focus/error state
    let focused = false;
    if (p.bindVar) {
        focused = input.getFocusedInput() === p.bindVar;
    }
    let strokeWidth = 1;
    if (focused) { bc = "rgba(102,153,255,1)"; strokeWidth = 2; }
    if (p.error) { bc = "#ef4444"; strokeWidth = 2; }

    // Draw field
    draw.roundedRect(x, y, w, h, bg, br, strokeWidth, bc, opacity);

    // Value or placeholder
    let value = p.value || "";
    let textColor = p.color || _theme.color;

    if (value) {
        draw.text(value, x + 8, y + 8, fontSize, 400, textColor,
            _theme.fontFamily, w - 16, opacity);
    } else if (p.placeholder) {
        let phColor = withAlpha(textColor, 0.5);
        draw.text(p.placeholder, x + 8, y + 8, fontSize, 400, phColor,
            _theme.fontFamily, w - 16, opacity);
    }

    // Cursor
    if (focused) {
        let cursorX = x + 8;
        if (value) {
            let measured = draw.measureText(value, fontSize, 400, _theme.fontFamily, w - 16);
            if (measured) cursorX = cursorX + measured.width;
        }
        let elapsed = input.getElapsedSecs();
        if ((elapsed * 2) % 2 < 1) {
            draw.rect(cursorX, y + 8 + fontSize * 0.15, 1.5, fontSize, textColor, 0, 0, "", opacity);
        }
    }
});

// ─── Select ─────────────────────────────────────────────────────────────────
registerComponent("Select", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;

    let currentY = y;

    // Label
    if (p.label) {
        draw.text(p.label, x, currentY, 14, 500, "rgba(217,217,222,1)",
            _theme.fontFamily, w, 1);
        currentY = currentY + 20;
    }

    // Field dimensions
    let size = p.size || "md";
    let fieldH = 40;
    if (size === "sm") fieldH = 32;
    else if (size === "lg") fieldH = 48;

    let bg = p.background || _theme.inputBg;
    let br = p.borderRadius !== undefined ? p.borderRadius : 6;
    let bc = p.borderColor || _theme.inputBorder;
    let fontSize = p.fontSize || 14;
    let disabled = p.disabled;
    let opacity = disabled ? 0.6 : 1;

    if (p.error) { bc = "#ef4444"; }

    draw.roundedRect(x, currentY, w, fieldH, bg, br, 1, bc, opacity);

    // Display value or placeholder
    let value = p.value || "";
    let displayText = "";
    if (value && p.options) {
        for (let i = 0; i < p.options.length; i++) {
            if (p.options[i].value === value) {
                displayText = p.options[i].label;
                break;
            }
        }
    }

    let textColor = p.color || _theme.color;
    let textY = currentY + (fieldH - fontSize * 1.2) / 2;

    if (displayText) {
        draw.text(displayText, x + 12, textY, fontSize, 400, textColor,
            _theme.fontFamily, w - 36, opacity);
    } else if (p.placeholder) {
        draw.text(p.placeholder, x + 12, textY, fontSize, 400, "rgba(161,161,168,1)",
            _theme.fontFamily, w - 36, opacity);
    }

    // Dropdown chevron arrow
    let arrowX = x + w - 20;
    let arrowY = currentY + fieldH / 2;
    let arrowColor = textColor;
    // V chevron: 3-point path
    let arrowPath = `M ${arrowX - 4} ${arrowY - 2} L ${arrowX} ${arrowY + 2} L ${arrowX + 4} ${arrowY - 2}`;
    draw.path(arrowPath, "", 0, arrowColor, 1.5, opacity);

    currentY = currentY + fieldH;

    // Error message
    if (p.error && p.errorMessage) {
        draw.text(p.errorMessage, x, currentY + 4, 12, 400, "#ef4444",
            _theme.fontFamily, w, 1);
    }
});

// ─── Switch ─────────────────────────────────────────────────────────────────
registerComponent("Switch", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;

    let size = p.size || "md";
    let trackW, trackH, thumbSize;
    if (size === "sm") { trackW = 32; trackH = 18; thumbSize = 14; }
    else if (size === "lg") { trackW = 56; trackH = 30; thumbSize = 26; }
    else { trackW = 44; trackH = 24; thumbSize = 20; }

    let checked = p.checked || false;
    let disabled = p.disabled;
    let opacity = disabled ? 0.5 : 1;

    let onColor = p.onColor || _theme.primary;
    let offColor = p.offColor || "rgba(100,100,100,1)";

    let trackY = y + (h - trackH) / 2;
    let trackRadius = trackH / 2;

    // Track
    let trackColor = checked ? onColor : offColor;
    draw.roundedRect(x, trackY, trackW, trackH, trackColor, trackRadius, 0, "", opacity);

    // Thumb
    let thumbX = checked ? (x + trackW - thumbSize - 2) : (x + 2);
    let thumbY = trackY + 2;
    let thumbRadius = thumbSize / 2;
    draw.roundedRect(thumbX, thumbY, thumbSize, thumbSize, "#ffffff", thumbRadius, 0, "", opacity);

    // Label
    if (p.label) {
        let labelX = x + trackW + 8;
        let labelY = y + (h - 14 * 1.2) / 2;
        if (p.description) labelY = labelY - 8;
        draw.text(p.label, labelX, labelY, 14, 500, "rgba(245,245,245,1)",
            _theme.fontFamily, w - trackW - 8, opacity);
    }
    // Description
    if (p.description) {
        let descX = x + trackW + 8;
        let descY = y + (h - 12 * 1.2) / 2 + 8;
        draw.text(p.description, descX, descY, 12, 400, "rgba(161,161,168,1)",
            _theme.fontFamily, w - trackW - 8, opacity);
    }
});

// ─── Checkbox ───────────────────────────────────────────────────────────────
registerComponent("Checkbox", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;

    let size = p.size || 18;
    let checked = p.checked || false;
    let color = p.color || _theme.primary;

    let boxX = x;
    let boxY = y + (h - size) / 2;

    if (checked) {
        // Filled box
        draw.roundedRect(boxX, boxY, size, size, color, 3, 0, "", 1);
        // Checkmark
        let cx = boxX + size / 2;
        let cy = boxY + size / 2;
        let s = size * 0.3;
        let checkPath = `M ${cx - s} ${cy} L ${cx - s * 0.3} ${cy + s * 0.7} L ${cx + s} ${cy - s * 0.5}`;
        draw.path(checkPath, "", 0, "#ffffff", 2, 1);
    } else {
        // Empty box with border
        draw.roundedRect(boxX, boxY, size, size, "", 3, 1.5, "rgba(153,153,153,1)", 1);
    }

    // Label
    if (p.label) {
        let labelX = x + size + 8;
        let labelY = y + (h - 14 * 1.2) / 2;
        draw.text(p.label, labelX, labelY, 14, 400, "rgba(230,230,230,1)",
            _theme.fontFamily, w - size - 8, 1);
    }
});

// ─── Radio ──────────────────────────────────────────────────────────────────
registerComponent("Radio", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;

    let size = p.size || 18;
    let checked = p.checked || false;
    let color = p.color || _theme.primary;

    let cx = x + size / 2;
    let cy = y + h / 2;
    let radius = size / 2;

    if (checked) {
        // Filled outer circle
        draw.circle(cx, cy, radius, color, 0, "", 1);
        // White inner dot
        draw.circle(cx, cy, radius * 0.4, "#ffffff", 0, "", 1);
    } else {
        // Empty circle with border
        draw.circle(cx, cy, radius, "", 1.5, "rgba(153,153,153,1)", 1);
    }

    // Label
    if (p.label) {
        let labelX = x + size + 8;
        let labelY = y + (h - 14 * 1.2) / 2;
        draw.text(p.label, labelX, labelY, 14, 400, "rgba(230,230,230,1)",
            _theme.fontFamily, w - size - 8, 1);
    }
});

// ─── Slider ─────────────────────────────────────────────────────────────────
registerComponent("Slider", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;

    let min = p.min !== undefined ? p.min : 0;
    let max = p.max !== undefined ? p.max : 100;
    let value = p.value !== undefined ? p.value : 0;
    let disabled = p.disabled;
    let opacity = disabled ? 0.5 : 1;

    let size = p.size || "md";
    let trackH, thumbSize;
    if (size === "sm") { trackH = 4; thumbSize = 12; }
    else if (size === "lg") { trackH = 8; thumbSize = 20; }
    else { trackH = 6; thumbSize = 16; }

    let color = p.color || _theme.primary;
    let trackColor = p.trackColor || "rgba(100,100,100,0.4)";

    let cy = y + h / 2;
    let trackY = cy - trackH / 2;
    let trackRadius = trackH / 2;

    // Background track
    draw.roundedRect(x, trackY, w, trackH, trackColor, trackRadius, 0, "", opacity);

    // Fill
    let range = max - min;
    let fraction = range > 0 ? Math.max(0, Math.min(1, (value - min) / range)) : 0;
    let fillW = w * fraction;
    if (fillW > 0) {
        draw.roundedRect(x, trackY, fillW, trackH, color, trackRadius, 0, "", opacity);
    }

    // Thumb
    let thumbX = x + fillW - thumbSize / 2;
    let thumbY = cy - thumbSize / 2;
    let thumbRadius = thumbSize / 2;
    draw.circle(thumbX + thumbRadius, thumbY + thumbRadius, thumbRadius, color, 0, "", opacity);
    draw.circle(thumbX + thumbRadius, thumbY + thumbRadius, thumbRadius * 0.5, "#ffffff", 0, "", opacity);
});

// ─── Default styles ─────────────────────────────────────────────────────────

registerDefaultStyle("Button", {
    display: "flex",
    flexDirection: "row",
    alignItems: "center",
    justifyContent: "center",
    paddingLeft: 16,
    paddingRight: 16,
    paddingTop: 8,
    paddingBottom: 8,
    flexShrink: 0
});

registerDefaultStyle("Input", {
    width: "100%",
    flexShrink: 0
});

registerDefaultStyle("TextArea", {
    width: "100%",
    height: 120,
    flexShrink: 0
});

registerDefaultStyle("Select", {
    width: "100%",
    flexShrink: 0
});

registerDefaultStyle("Switch", {
    display: "flex",
    flexDirection: "row",
    alignItems: "center",
    height: 24,
    flexShrink: 0
});

registerDefaultStyle("Checkbox", {
    display: "flex",
    flexDirection: "row",
    alignItems: "center",
    height: 24,
    flexShrink: 0
});

registerDefaultStyle("Radio", {
    display: "flex",
    flexDirection: "row",
    alignItems: "center",
    height: 24,
    flexShrink: 0
});

registerDefaultStyle("Slider", {
    width: "100%",
    height: 24,
    flexShrink: 0
});

// ============================================================================
// Display Components: Badge, NavItem, Placeholder, Image, Avatar, Progress,
//                     Spinner, Skeleton, Tag, Modal, Toast
// ============================================================================

// ─── Badge ──────────────────────────────────────────────────────────────────
registerComponent("Badge", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;

    let bg = p.background || _theme.primary;
    let color = p.color || "#ffffff";
    let badgeStyle = p.badgeStyle || "solid";
    let pill = p.pill || false;
    let size = p.size || "md";

    let br;
    if (pill) { br = 9999; }
    else if (size === "xs" || size === "sm") { br = 4; }
    else if (size === "lg") { br = 8; }
    else { br = 6; }

    let fontSize = 12;
    if (size === "xs") fontSize = 10;
    else if (size === "sm") fontSize = 11;
    else if (size === "lg") fontSize = 14;

    if (badgeStyle === "solid") {
        draw.roundedRect(x, y, w, h, bg, br, 0, "", 1);
    } else if (badgeStyle === "subtle") {
        draw.roundedRect(x, y, w, h, withAlpha(bg, 0.5), br, 0, "", 1);
    } else if (badgeStyle === "outline") {
        draw.roundedRect(x, y, w, h, "", br, 1, color, 1);
    }

    let label = p.label || "";
    if (label) {
        let px = size === "xs" ? 4 : (size === "sm" ? 6 : (size === "lg" ? 10 : 8));
        let textY = y + (h - fontSize * 1.2) / 2;
        draw.text(label, x + px, textY, fontSize, 500, color,
            _theme.fontFamily, w - px * 2, 1);
    }
});

// ─── NavItem ────────────────────────────────────────────────────────────────
registerComponent("NavItem", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;

    let active = p.active || false;

    if (active) {
        // Active background highlight
        draw.roundedRect(x, y, w, h, "rgba(99,102,241,0.1)", 8, 0, "", 1);
        // Left accent bar
        let barH = h * 0.6;
        let barY = y + (h - barH) / 2;
        draw.roundedRect(x, barY, 3, barH, "#6366f1", 2, 0, "", 1);
    }

    // Label
    let label = p.label || "";
    if (label) {
        let textColor = active ? "#ffffff" : "#a1a1aa";
        let textWeight = active ? 500 : 400;
        let textX = x + 32;
        let textY = y + (h - 14 * 1.2) / 2;
        draw.text(label, textX, textY, 14, textWeight, textColor,
            _theme.fontFamily, w - 44, 1);
    }
});

// ─── Placeholder ────────────────────────────────────────────────────────────
registerComponent("Placeholder", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;

    // Faint fill
    draw.roundedRect(x, y, w, h, "rgba(255,255,255,0.03)", 8, 0, "", 1);
    // Dashed border (approximated as solid since we don't have dash support)
    draw.roundedRect(x, y, w, h, "", 8, 1.5, "rgba(255,255,255,0.2)", 1);

    // Centered name text
    let name = p.componentName || p.name || "Placeholder";
    let fontSize = 13;
    let textW = name.length * fontSize * 0.55;
    let textX = x + (w - textW) / 2;
    let textY = y + (h - fontSize * 1.2) / 2;
    draw.text(name, textX, textY, fontSize, 400, "rgba(255,255,255,0.3)",
        _theme.fontFamily, w, 1);
});

// ─── Image ──────────────────────────────────────────────────────────────────
registerComponent("Image", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;

    let bg = p.background || "rgba(40,40,50,1)";
    let br = p.borderRadius || 0;

    // Background placeholder
    draw.roundedRect(x, y, w, h, bg, br, 0, "", 1);

    // Mountain icon (placeholder for actual image)
    let iconSize = Math.min(24, w * 0.3, h * 0.3);
    if (iconSize > 4) {
        let iconX = x + (w - iconSize) / 2;
        let iconY = y + (h - iconSize) / 2 - 8;
        // Simple mountain shape
        let mx = iconX;
        let my = iconY + iconSize;
        let path = `M ${mx} ${my} L ${mx + iconSize * 0.3} ${iconY + iconSize * 0.3} L ${mx + iconSize * 0.5} ${iconY + iconSize * 0.5} L ${mx + iconSize * 0.7} ${iconY} L ${mx + iconSize} ${my} Z`;
        draw.path(path, "rgba(255,255,255,0.2)", 0, "", 0, 1);
    }

    // Alt text
    let alt = p.alt || p.src || "";
    if (alt) {
        if (alt.length > 30) alt = alt.slice(0, 30);
        let fontSize = 11;
        let textW = alt.length * fontSize * 0.55;
        let textX = x + (w - textW) / 2;
        let textY = y + h / 2 + 8;
        draw.text(alt, textX, textY, fontSize, 400, "rgba(255,255,255,0.3)",
            _theme.fontFamily, w - 8, 1);
    }
});

// ─── Avatar ─────────────────────────────────────────────────────────────────
registerComponent("Avatar", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let size = p.size || cl.width;

    let bg = p.background || _theme.primary;
    let color = p.color || "#ffffff";
    let br = p.borderRadius !== undefined ? p.borderRadius : (size / 2);

    // Background shape
    draw.roundedRect(x, y, size, size, bg, br, 0, "", 1);

    // Border
    if (p.border) {
        let bc = p.borderColor || "rgba(255,255,255,0.2)";
        draw.roundedRect(x, y, size, size, "", br, 2, bc, 1);
    }

    // Fallback initials
    let fallback = p.fallback || "";
    if (!fallback && p.name) {
        let parts = p.name.split(" ");
        fallback = "";
        for (let i = 0; i < Math.min(2, parts.length); i++) {
            if (parts[i].length > 0) fallback = fallback + parts[i][0].toUpperCase();
        }
    }

    if (fallback) {
        let fontSize = size * 0.4;
        let measured = draw.measureText(fallback, fontSize, 700, _theme.fontFamily, 0);
        let textW = measured ? measured.width : (fallback.length * fontSize * 0.6);
        let textX = x + (size - textW) / 2;
        let textY = y + (size - fontSize) / 2;
        draw.text(fallback, textX, textY, fontSize, 700, color,
            _theme.fontFamily, size, 1);
    }

    // Status indicator
    let status = p.status;
    if (status && status !== "none") {
        let dotSize = Math.max(6, size * 0.25);
        let dotX = x + size - dotSize;
        let dotY = y + size - dotSize;

        // Dark outline ring
        draw.circle(dotX + dotSize / 2, dotY + dotSize / 2, dotSize / 2 + 1.5, "#09090b", 0, "", 1);

        // Status dot
        let dotColor;
        if (status === "online") dotColor = "#22c55e";
        else if (status === "offline") dotColor = "#9ca3af";
        else if (status === "away") dotColor = "#f59e0b";
        else if (status === "busy") dotColor = "#ef4444";
        else dotColor = "#9ca3af";
        draw.circle(dotX + dotSize / 2, dotY + dotSize / 2, dotSize / 2, dotColor, 0, "", 1);
    }
});

// ─── Progress ───────────────────────────────────────────────────────────────
registerComponent("Progress", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;

    let value = p.value !== undefined ? p.value : 0;
    let max = p.max !== undefined ? p.max : 100;
    let color = p.color || _theme.primary;
    let trackColor = p.trackColor || "rgba(100,100,100,0.3)";
    let barH = p.height || h;
    let br = p.borderRadius !== undefined ? p.borderRadius : (barH / 2);

    // Track
    draw.roundedRect(x, y, w, barH, trackColor, br, 0, "", 1);

    // Fill
    let fraction = max > 0 ? Math.max(0, Math.min(1, value / max)) : 0;
    let fillW = w * fraction;
    if (fillW > 0) {
        draw.roundedRect(x, y, fillW, barH, color, br, 0, "", 1);
    }

    // Label
    if (p.showLabel) {
        let pct = Math.round(fraction * 100) + "%";
        let fontSize = Math.max(barH - 2, 10);
        draw.text(pct, x + 4, y + (barH - fontSize * 1.2) / 2, fontSize, 700, "#ffffff",
            _theme.fontFamily, w - 8, 1);
    }
});

// ─── Spinner ────────────────────────────────────────────────────────────────
registerComponent("Spinner", (node, cl) => {
    let p = node.props;
    let cx = cl.x + cl.width / 2;
    let cy = cl.y + cl.height / 2;
    let size = p.size || Math.min(cl.width, cl.height);
    let thickness = p.thickness || 3;
    let color = p.color || _theme.primary;

    let radius = size / 2 - thickness;
    let elapsed = input.getElapsedSecs();
    let startAngle = elapsed * 4;
    let arcAngle = Math.PI * 1.5; // 270 degrees

    // Draw arc as polyline segments
    let segments = 32;
    let path = "";
    for (let i = 0; i <= segments; i++) {
        let a = startAngle + (i / segments) * arcAngle;
        let px = cx + Math.cos(a) * radius;
        let py = cy + Math.sin(a) * radius;
        if (i === 0) path = `M ${px} ${py}`;
        else path = path + ` L ${px} ${py}`;
    }
    draw.path(path, "", 0, color, thickness, 1);
});

// ─── Skeleton ───────────────────────────────────────────────────────────────
registerComponent("Skeleton", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;
    let variant = p.variant || "rect";

    let elapsed = input.getElapsedSecs();
    let alpha = 0.15 + 0.1 * Math.sin(elapsed * 2);

    let color = `rgba(255,255,255,${alpha})`;

    if (variant === "circle") {
        let r = Math.min(w, h) / 2;
        draw.circle(x + w / 2, y + h / 2, r, color, 0, "", 1);
    } else {
        let br = p.borderRadius || 4;
        draw.roundedRect(x, y, w, h, color, br, 0, "", 1);
    }
});

// ─── Tag ────────────────────────────────────────────────────────────────────
registerComponent("Tag", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;

    let bg = p.background || _theme.primary;
    let color = p.color || "#ffffff";
    let br = p.borderRadius !== undefined ? p.borderRadius : 4;

    draw.roundedRect(x, y, w, h, bg, br, 0, "", 1);

    let label = p.label || "";
    if (label) {
        let textY = y + (h - 12 * 1.2) / 2;
        draw.text(label, x + 8, textY, 12, 500, color,
            _theme.fontFamily, w - 16, 1);
    }
});

// ─── Modal ──────────────────────────────────────────────────────────────────
registerComponent("Modal", (node, cl) => {
    let p = node.props;
    if (!p.open) return;

    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;

    // Backdrop overlay
    draw.rect(x, y, w, h, "rgba(0,0,0,0.5)", 0, 0, "", 1);

    // Centered card
    let cardW = Math.min(p.width || 480, w - 32);
    let cardH = Math.min(h * 0.6, h - 32);
    let bg = p.background || "#1e1e23";
    let br = p.borderRadius || 12;

    let cardX = x + (w - cardW) / 2;
    let cardY = y + (h - cardH) / 2;

    draw.roundedRect(cardX, cardY, cardW, cardH, bg, br, 0, "", 1);
});

// ─── Toast ──────────────────────────────────────────────────────────────────
registerComponent("Toast", (node, cl) => {
    let p = node.props;
    let x = cl.x;
    let y = cl.y;
    let w = cl.width;
    let h = cl.height;

    let bg = p.background || "#1e293b";
    let color = p.color || "#ffffff";

    // Drop shadow
    draw.roundedRect(x + 2, y + 2, w, h, "rgba(0,0,0,0.3)", 8, 0, "", 1);
    // Card
    draw.roundedRect(x, y, w, h, bg, 8, 0, "", 1);

    // Message
    let msg = p.message || "";
    if (msg) {
        let textY = y + (h - 14 * 1.2) / 2;
        draw.text(msg, x + 12, textY, 14, 500, color,
            _theme.fontFamily, w - 24, 1);
    }
});

